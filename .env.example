# ============================================
# VARIAVEIS DE AMBIENTE - AQUI ACAI
# ============================================
# Copie este arquivo para .env ou .env.local
# Preencha com suas credenciais do Supabase
# ============================================

# URL do Projeto Supabase
# Obter em: https://app.supabase.com → Settings → API
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave Anon/Public do Supabase
# Obter em: https://app.supabase.com → Settings → API
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# EXEMPLO:
# VITE_SUPABASE_URL=https://abcdefghij.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFiY2RlZmdoaWoiLCJyb2xlIjoiYW5vbiIsImlhdCI6MTYx...
# ============================================
